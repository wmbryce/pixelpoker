{
  "name": "pixelpoker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["client", "server", "shared"],
  "scripts": {
    "dev": "concurrently \"bun --filter server dev\" \"bun --filter client dev\"",
    "build": "bun --filter client build",
    "start": "bun --filter server start",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "test": "bun --filter server test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.3.3",
    "typescript": "^6.0.2"
  }
}
